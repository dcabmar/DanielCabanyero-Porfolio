---
// src/components/Competencias.astro
---

<section id="competencias" class="py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-5">
        <h2 class="text-5xl font-extrabold text-center mb-16 text-white">Competencias</h2>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
            
            <div class="bg-white/5 p-8 rounded-xl text-center border border-white/10 hover:bg-white/10 transition-all hover:-translate-y-1">
                <img src="https://bambu-mobile.com/wp-content/uploads/2022/06/Lenguajes-de-programacion-del-futuro-programacion-lenguajes-de-programacion-python-JS-C-Java-1536x1024.jpg" alt="Icono Programación" class="w-28 h-28 rounded-full border-4 border-white mx-auto mb-6 object-cover bg-white/20 p-2 shadow-lg"/>
                <h3 class="text-2xl font-bold mb-5 text-white">Programación</h3>
                <ul class="text-left text-sm space-y-2 text-gray-100 list-disc list-outside pl-5">
                    <li>Python, html, css, JavaScript, Java, C++, C#, Arduino, MySQL, Github, Unity, IA y Modelos de Aprendizaje, Docker, Azure, IoT/Sistemas Embebidos, Frameworks.</li>
                </ul>
            </div>

            <div class="bg-white/5 p-8 rounded-xl text-center border border-white/10 hover:bg-white/10 transition-all hover:-translate-y-1">
                <img src="https://img.freepik.com/premium-photo/top-view-graphic-designer-with-tablet_327072-54540.jpg" alt="Icono Diseño" class="w-28 h-28 rounded-full border-4 border-white mx-auto mb-6 object-cover bg-white/20 p-2 shadow-lg"/>
                <h3 class="text-2xl font-bold mb-5 text-white">Diseño</h3>
                <ul class="text-left text-sm space-y-2 text-gray-100 list-disc list-outside pl-5">
                    <li>Diseño Web</li>
                    <li>Diseño y animación 2D</li>
                    <li>Diseño y Animación 3D</li>
                    <li>Impresión 3D</li>
                    <li>Canva</li>
                    <li>Narrativa Visual</li>
                </ul>
            </div>

            <div class="bg-white/5 p-8 rounded-xl text-center border border-white/10 hover:bg-white/10 transition-all hover:-translate-y-1">
                <img src="https://elinformedigital.com/wp-content/uploads/2024/06/Como-la-produccion-de-contenido-multimedia-esta-transformando-el-mundo-digital.jpg" alt="Icono Producción" class="w-28 h-28 rounded-full border-4 border-white mx-auto mb-6 object-cover bg-white/20 p-2 shadow-lg"/>
                <h3 class="text-2xl font-bold mb-5 text-white">Producción y Posproducción</h3>
                <ul class="text-left text-sm space-y-2 text-gray-100 list-disc list-outside pl-5">
                    <li>Guión y StoryTelling</li>
                    <li>Grabación de video</li>
                    <li>Grabación de audio</li>
                    <li>Edición de video: DaVinci Resolve, Adobe Audition, Reaper, Sony Vegas</li>
                    <li>Edición de audio</li>
                    <li>CGI</li>
                </ul>
            </div>

            <div class="bg-white/5 p-8 rounded-xl text-center border border-white/10 hover:bg-white/10 transition-all hover:-translate-y-1">
                <img src="https://gamco.es/wp-content/uploads/2022/03/equipo-gamco-inteligencia-artificial-768x512.png" alt="Icono Empresa" class="w-28 h-28 rounded-full border-4 border-white mx-auto mb-6 object-cover bg-white/20 p-2 shadow-lg"/>
                <h3 class="text-2xl font-bold mb-5 text-white">Entorno Empresarial</h3>
                <ul class="text-left text-sm space-y-2 text-gray-100 list-disc list-outside pl-5">
                    <li>Dirección de Proyectos</li>
                    <li>Conocimientos en:</li>
                    <ul class="list-circle list-outside pl-5 space-y-1 mt-1"> 
                        <li>Modelos de Negocio</li>
                        <li>Marketing Digital</li>
                    </ul>
                    <li>SEO</li>
                    <li>Gestión de Redes Sociales / Community Management</li>
                </ul>
            </div>

            <div class="bg-white/5 p-8 rounded-xl text-center border border-white/10 hover:bg-white/10 transition-all hover:-translate-y-1">
                <img src="https://www.alphatrad.es/sites/alphatrad.es/files/images/articles/idiomas%20mas%20hablados%20en%20el%20mundo.jpg" alt="Icono Idiomas" class="w-28 h-28 rounded-full border-4 border-white mx-auto mb-6 object-cover bg-white/20 p-2 shadow-lg"/>
                <h3 class="text-2xl font-bold mb-5 text-white">Idiomas</h3>
                <ul class="text-left text-sm space-y-2 text-gray-100 list-disc list-outside pl-5">
                    <li>Español: Nativo</li>
                    <li>Valenciano: Nivel Alto</li>
                    <li>Inglés: Nivel Avanzado(C1)</li>
                </ul>
            </div>

            <div class="bg-white/5 p-8 rounded-xl text-center border border-white/10 hover:bg-white/10 transition-all hover:-translate-y-1">
                <img src="https://cdn.vectorstock.com/i/preview-1x/53/06/multitalented-worker-multiple-project-management-vector-49975306.jpg" alt="Icono Habilidades" class="w-28 h-28 rounded-full border-4 border-white mx-auto mb-6 object-cover bg-white/20 p-2 shadow-lg"/>
                <h3 class="text-2xl font-bold mb-5 text-white">Otras Habilidades</h3>
                <ul class="text-left text-sm space-y-2 text-gray-100 list-disc list-outside pl-5">
                    <li>Creatividad e innovación</li>
                    <li>Trabajo en equipo</li>
                    <li>Cooperación</li>
                    <li>Adaptación a la situación</li>
                    <li>Gestión del Tiempo</li>
                    <li>Resolución de Problemas (Debugging)</li>
                </ul>
            </div>

        </div> 
    </div>
</section>